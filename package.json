{
  "name": "web2hls-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\"",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "eslint": "^9.22.0",
    "prettier": "^3.5.0",
    "tsup": "^8.4.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
