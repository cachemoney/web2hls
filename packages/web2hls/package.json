{
  "name": "web2hls",
  "version": "0.1.0",
  "description": "Record HTML canvas to HLS live streams using WebCodecs and MPEG-TS muxing",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "mediabunny": "^1.40.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.4.0"
  },
  "license": "MIT",
  "keywords": ["webcodecs", "hls", "mpeg-ts", "canvas", "streaming", "youtube", "live"],
  "sideEffects": false
}
